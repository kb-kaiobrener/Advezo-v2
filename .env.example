# ── Security ─────────────────────────────────
# 32-byte hex secret for HMAC-SHA256 phone hashing
# Generate: openssl rand -hex 32
GLOBAL_HMAC_SECRET=5d47eb7ccbdd86a1b03696f67a449636b3dd1adce6191acbfc14aa99074d4fd1

# Criptografia de tokens OAuth (AES-256-GCM)
# DEVE ser distinta entre dev/staging/produção (NFR-7) — nunca reutilizar a chave da v1.
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=28a488669f9cff051bb357e3d9938f567bbbbcb8ed676ac6a4fa85d402993740

# ── Meta Ads Sandbox (Epic 2 — Story 2.1) ────
# Facebook Developer App (modo desenvolvimento) + Meta Test Ad Account
META_APP_ID=2106611180260713
META_APP_SECRET=89415241de148cc180b95c7315668456
META_REDIRECT_URI=http://localhost:3000/api/oauth/meta/callback
META_TEST_AD_ACCOUNT_ID=act_XXXXXXXXXX

# ── Google Ads Sandbox (Epic 2 — Story 2.2) ──
# Google OAuth + Google Ads API test account (is_test_account: true)
# Developer Token: nível "test" em sandbox; produção requer aprovação manual Google (PC-03)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_TEST_CUSTOMER_ID=your-test-customer-id
GOOGLE_ADS_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback

# ── App ──────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Railway Workers ──────────────────────────
RAILWAY_WHATSAPP_WORKER_URL=http://localhost:3001
RAILWAY_CLASSIFICATION_WORKER_URL=http://localhost:3002

# ── Cron / Sync (Epic 2 — Story 2.3) ─────────
# Segredo compartilhado entre o cron Railway e o endpoint POST /api/sync/meta.
# O Railway envia o header `x-cron-secret: $CRON_SECRET`; o endpoint retorna 401
# se ausente ou diferente. String aleatória, mín. 32 chars.
# DEVE diferir entre dev/staging/produção (NFR-7) — nunca reutilizar entre ambientes.
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=00b15bfb0867a2e64bc13d87a536fc50cb508af276e4a5afddbe02c886073b55

# ── AIOX Framework (framework tooling only) ──
# These are used by AIOX CLI tools, not by the Advezo app itself
ANTHROPIC_API_KEY=your-anthropic-api-key