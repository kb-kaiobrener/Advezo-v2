# ============================================
# Advezo v2 — Environment Variables
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local with real credentials.
# ============================================

# ── Supabase ─────────────────────────────────
# Public vars (safe for client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — NEVER expose in NEXT_PUBLIC_*
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Security ─────────────────────────────────
# 32-byte hex secret for HMAC-SHA256 phone hashing
# Generate: openssl rand -hex 32
GLOBAL_HMAC_SECRET=your-32-byte-hex-secret

# 32-byte hex key for AES-256 ad account token encryption
# Generate: openssl rand -hex 32
AD_ACCOUNT_ENCRYPTION_KEY=your-32-byte-hex-key

# ── App ──────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Railway Workers ──────────────────────────
RAILWAY_WHATSAPP_WORKER_URL=http://localhost:3001
RAILWAY_CLASSIFICATION_WORKER_URL=http://localhost:3002

# ── AIOX Framework (framework tooling only) ──
# These are used by AIOX CLI tools, not by the Advezo app itself
ANTHROPIC_API_KEY=your-anthropic-api-key
